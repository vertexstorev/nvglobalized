{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web2",
  "main": "src/b_worker.js",
  "compatibility_date": "2026-05-14",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}